# Google Gemini API Key (Secret, server-side only)
# Get a key from Google AI Studio
GEMINI_API_KEY=

# Google AdSense Publisher ID (Optional, for ads.txt validation)
# Format: pub-xxxxxxxxxxxxxxxx
ADSENSE_PUB_ID=

# Your Production Application URL (Optional, for sitemap.xml generation)
# Example: https://yourdomain.com
APP_URL=

# Hostinger SMTP configuration for Contact Form (e.g. yt@transcriptg.com)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=yt@transcriptg.com
SMTP_PASS=
